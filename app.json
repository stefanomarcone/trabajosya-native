{
  "expo": {
    "name": "TrabajosYa",
    "slug": "trabajosya-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1d4ed8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "cl.trabajosya.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1d4ed8"
      },
      "package": "cl.trabajosya.twa",
      "versionCode": 10,
      "edgeToEdgeEnabled": true
    },
    "plugins": [],
    "extra": {
      "eas": {
        "projectId": "3d729bf3-3d63-4e4c-a8b0-ddf21ac7afda"
      }
    },
    "owner": "smboss"
  }
}
